{
    "gateway": {
        "mode": "local",
        "bind": "lan",
        "trustedProxies": ["172.16.0.0/12"],
        "auth": {
            "mode": "token",
            "rateLimit": {
                "maxAttempts": 10,
                "windowMs": 60000,
                "lockoutMs": 300000,
                "exemptLoopback": true
            }
        },
        "controlUi": {
            "allowedOrigins": [
                "https://hackathon-mc01.tailb36ad3.ts.net",
                "https://hackathon-mc01.tailb36ad3.ts.net:8443"
            ]
        }
    },
    "session": {
        "dmScope": "per-channel-peer"
    },
    "tools": {
        "fs": {
            "workspaceOnly": true
        },
        "exec": {
            "security": "full"
        }
    },

    "models": {
        "mode": "merge",
        "providers": {
            "anthropic": {
                "baseUrl": "https://api.anthropic.com",
                "apiKey": "${ANTHROPIC_API_KEY}",
                "api": "anthropic-messages",
                "models": [
                    {
                        "id": "claude-opus-4-6",
                        "name": "Claude Opus 4.6"
                    },
                    {
                        "id": "claude-sonnet-4-6",
                        "name": "Claude Sonnet 4.6"
                    },
                    {
                        "id": "claude-haiku-4-5",
                        "name": "Claude Haiku 4.5"
                    }
                ]
            }
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "anthropic/claude-opus-4-6"
            },
            "memorySearch": {
                "provider": "voyage",
                "remote": {
                    "apiKey": "${VOYAGE_API_KEY}"
                },
                "query": {
                    "hybrid": {
                        "enabled": true,
                        "vectorWeight": 0.7,
                        "textWeight": 0.3,
                        "candidateMultiplier": 4,
                        "mmr": {
                            "enabled": true,
                            "lambda": 0.7
                        },
                        "temporalDecay": {
                            "enabled": true,
                            "halfLifeDays": 7
                        }
                    }
                }
            },
            "bootstrapMaxChars": 25000,
            "bootstrapTotalMaxChars": 180000
        },
        "list": [
            {
                "id": "manager",
                "name": "Product Owner",
                "default": true,
                "workspace": "/app/config/agents/manager",
                "subagents": {
                    "allowAgents": [
                        "architect",
                        "engineer",
                        "reviewer",
                        "researcher",
                        "ui-checker",
                        "social-lead"
                    ]
                }
            },
            {
                "id": "architect",
                "name": "System Architect",
                "workspace": "/app/config/agents/architect",
                "model": {
                    "primary": "anthropic/claude-opus-4-6"
                }
            },
            {
                "id": "engineer",
                "name": "Software Engineer",
                "workspace": "/app/config/agents/engineer",
                "model": {
                    "primary": "anthropic/claude-sonnet-4-6",
                    "fallbacks": [
                        "anthropic/claude-haiku-4-5"
                    ]
                }
            },
            {
                "id": "reviewer",
                "name": "Code Reviewer",
                "workspace": "/app/config/agents/reviewer",
                "model": {
                    "primary": "anthropic/claude-opus-4-6"
                }
            },
            {
                "id": "researcher",
                "name": "Web3 Researcher",
                "workspace": "/app/config/agents/researcher",
                "model": {
                    "primary": "anthropic/claude-haiku-4-5"
                }
            },
            {
                "id": "ui-checker",
                "name": "UI/UX Specialist",
                "workspace": "/app/config/agents/ui-checker",
                "skills": [
                    "ui-ux-pro-max"
                ],
                "model": {
                    "primary": "anthropic/claude-sonnet-4-6"
                }
            },
            {
                "id": "social-lead",
                "name": "Social Media Lead",
                "workspace": "/app/config/agents/social-lead",
                "model": {
                    "primary": "anthropic/claude-sonnet-4-6"
                }
            }
        ]
    }
}
