{
    "gateway": {
        "mode": "local",
        "bind": "lan",
        "auth": {
            "mode": "token",
            "rateLimit": {
                "maxAttempts": 10,
                "windowMs": 60000,
                "lockoutMs": 300000,
                "exemptLoopback": true
            }
        },
        "controlUi": {
            "allowedOrigins": [
                "https://hackathon-mc01.tailb36ad3.ts.net"
            ]
        }
    },
    "session": {
        "dmScope": "per-channel-peer"
    },
    "tools": {
        "fs": {
            "workspaceOnly": true
        },
        "exec": {
            "security": "full"
        }
    },
    "models": {
        "mode": "merge",
        "providers": {
            "anthropic": {
                "baseUrl": "https://api.anthropic.com",
                "apiKey": "${ANTHROPIC_API_KEY}",
                "api": "anthropic-messages",
                "models": [
                    {
                        "id": "claude-opus-4-6",
                        "name": "Claude Opus 4.6"
                    },
                    {
                        "id": "claude-sonnet-4-6",
                        "name": "Claude Sonnet 4.6"
                    },
                    {
                        "id": "claude-haiku-4-5",
                        "name": "Claude Haiku 4.5"
                    }
                ]
            }
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "anthropic/claude-sonnet-4-6"
            }
        },
        "list": [
            {
                "id": "manager",
                "name": "Project Manager",
                "default": true,
                "subagents": {
                    "allowAgents": [
                        "architect",
                        "engineer",
                        "reviewer",
                        "researcher",
                        "ui-checker"
                    ]
                }
            },
            {
                "id": "architect",
                "name": "System Architect",
                "model": {
                    "primary": "anthropic/claude-opus-4-6"
                }
            },
            {
                "id": "engineer",
                "name": "Software Engineer",
                "model": {
                    "primary": "anthropic/claude-sonnet-4-6",
                    "fallbacks": [
                        "anthropic/claude-haiku-4-5"
                    ]
                }
            },
            {
                "id": "reviewer",
                "name": "Code Reviewer",
                "model": {
                    "primary": "anthropic/claude-opus-4-6"
                }
            },
            {
                "id": "researcher",
                "name": "Context Researcher",
                "model": {
                    "primary": "anthropic/claude-haiku-4-5"
                }
            },
            {
                "id": "ui-checker",
                "name": "UI/UX Specialist",
                "model": {
                    "primary": "anthropic/claude-sonnet-4-6"
                }
            }
        ]
    }
}
